

# LLM CONFIGURATION:
# ----------------------------------------------------------------------
# Either set anthropic key if you want to use anthropic API OR
ANTHROPIC_API_KEY=
# OR localhost LLM model if you have a local LLM server running.
LOCAL_LLM_MODEL="mistralai/ministral-3-14b-reasoning"
LOCAL_EMBEDDING_MODEL="text-embedding-nomic-embed-text-v1"
LOCAL_LLM_URL="http://localhost:1234/v1"
# ----------------------------------------------------------------------

# Fitbit config - you can get these from https://dev.fitbit.com/apps/new
FITBIT_CLIENT_SECRET=
FITBIT_CLIENT_ID=

# Perplexity API key - you can get this from https://www.perplexity.ai/api
PERPLEXITY_API_KEY=

# OpenAI API key used for embeddings - you can get this from https://platform.openai.com/account/api-keys
OPENAI_API_KEY=

# Withings API credentials - you can get these from https://developer.withings.com/
WITHINGS_CLIENT_ID=
WITHINGS_CLIENT_SECRET=
WITHINGS_API_ENDPOINT="https://wbsapi.withings.net"

# Todoist API key - you can get this from https://developer.todoist.com/appconsole.html
TODOIST_KEY=
# IF you want to use a cron job to scan todoist every 5 minutes
AI_PROJECT_ID=

# Database configuration
# Set DB_TYPE to "postgres" or "sqlite" to choose which database backend to use
DB_TYPE="postgres"

# PostgreSQL settings (used when DB_TYPE=postgres)
# postgres.app defaults: host=localhost, port=5432, user=<your OS username>, password=<empty>
DB_POSTGRES_HOST="localhost"
DB_POSTGRES_PORT="5432"
DB_POSTGRES_DATABASE="agentdb" # Change this for your database name
DB_POSTGRES_USER="postgres"
DB_POSTGRES_PASSWORD=""

# SQLite settings (used when DB_TYPE=sqlite)
DB_SQLITE_PATH="./data/agent.db"

